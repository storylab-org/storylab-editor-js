# Copy this file to .env and fill in your values
# Note: Variables must be prefixed with VITE_ to be exposed to the client in Vite

# API Configuration
VITE_API_BASE=http://localhost:3000

# App Configuration
VITE_APP_NAME=Storylab
VITE_APP_VERSION=0.1.0

# Feature Flags (set to true/false)
VITE_DEBUG_MODE=true
VITE_SHOW_TREE_VIEW=true
VITE_SHOW_ERROR_DISPLAY=true

# Server Configuration (see server/.env.example for server-specific variables)
# These are not exposed to the frontend (no VITE_ prefix)
