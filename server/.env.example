# Server Environment Variables
# Copy to server/.env if needed (optional - all have sensible defaults)

# Server Port (default: 3000)
PORT=3000

# Server Host (default: 0.0.0.0)
HOST=0.0.0.0

# Logging Level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Image Upload Configuration
# Maximum image file size in megabytes (default: 50MB)
# Users will receive a friendly error message if they exceed this limit
MAX_IMAGE_SIZE_MB=50

# Data Directory (default: ~/.storylab)
# Stores blocks, heads, and image metadata
# STORYLAB_DATA_DIR=/custom/path/.storylab
