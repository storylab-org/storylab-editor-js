{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "storylab",
  "version": "0.2.91",
  "identifier": "com.yannik.storylab",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:ts --prefix server",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "storylab",
        "width": 1100,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../server/dist/**/*"]
  }
}
